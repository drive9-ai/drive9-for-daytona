# Daytona API key — get one from https://app.daytona.io
DAYTONA_API_KEY=daytona_...

# drive9 credentials for mounting shared workspaces.
DRIVE9_SERVER=https://api.drive9.ai
DRIVE9_API_KEY=your-drive9-api-key

# Remote root mounted inside the sandbox at /home/daytona/workspace.
DRIVE9_REMOTE=:/daytona-demo

# ── LLM (any OpenAI-compatible provider) ─────────────────────────────
# Optional — falls back to deterministic output without LLM_API_KEY.
LLM_API_KEY=sk-...
# LLM_MODEL=qwen3-coder-plus
# LLM_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions

# Allow deterministic fallback when LLM API call fails.
# ALLOW_AI_FALLBACK=1
