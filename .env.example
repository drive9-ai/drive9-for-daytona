# Daytona API key — get one from https://app.daytona.io
DAYTONA_API_KEY=daytona_...

# Daytona target region (e.g. us, eu). Set a default in your Daytona Dashboard,
# or specify here to override.
# DAYTONA_TARGET=us

# drive9 credentials for mounting shared workspaces.
DRIVE9_SERVER=https://api.drive9.ai
DRIVE9_API_KEY=your-drive9-api-key

# Remote root mounted inside the sandbox at /home/daytona/workspace.
DRIVE9_REMOTE=:/daytona-demo
